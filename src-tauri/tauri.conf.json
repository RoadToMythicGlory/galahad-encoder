{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Galahad Encoder",
  "version": "0.1.0",
  "identifier": "gg.galahad.encoder",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Galahad Encoder",
        "width": 1040,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["binaries/ffmpeg.exe"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "longDescription": "Galahad Encoder captures a selected game window plus its audio, the player's microphone, and Discord audio, then streams it as an SRT caller into the OBS matrix. Players only enter a destination IP and port.",
    "shortDescription": "Windows player encoder for SRT broadcast."
  },
  "plugins": {}
}
